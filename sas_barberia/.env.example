# CONFIGURACIÓN DE SUPABASE - BARBERÍA EL IMPERIO
# Renombra este archivo a `.env` y coloca tus claves reales de Supabase

# URL de tu API de Supabase (encuéntrala en Settings -> API)
VITE_SUPABASE_URL=https://tu-proyecto-id.supabase.co

# Llave Anónima Pública de Supabase (encuéntrala en Settings -> API)
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica-de-supabase-ejemplo-completo-de-texto-largo
