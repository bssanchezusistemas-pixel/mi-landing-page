# Copia este archivo a .env y rellena tus credenciales de n8n.
# Nunca subas .env al repositorio.

# API key: n8n → Settings → API → Create API Key
N8N_API_KEY=

# --- n8n local (por defecto en este kit) ---
N8N_API_URL=http://localhost:5678/api/v1
N8N_WEBHOOK_URL=http://localhost:5678

# MCP nativo de n8n (configurado en .cursor/mcp.json)
# http://localhost:5678/mcp-server/http

# --- n8n remoto (si no usas localhost) ---
# N8N_API_URL=https://tu-n8n.dominio.com/api/v1
# N8N_WEBHOOK_URL=https://tu-n8n.dominio.com
