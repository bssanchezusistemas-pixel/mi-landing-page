# Copia este archivo a .env y rellena tus credenciales de n8n.
# Nunca subas .env al repositorio.

# URL base de la API (incluye /api/v1)
N8N_API_URL=https://tu-n8n.dominio.com/api/v1

# API key: n8n → Settings → API → Create API Key
N8N_API_KEY=

# URL pública de tu instancia (sin /api/v1)
N8N_WEBHOOK_URL=https://tu-n8n.dominio.com
