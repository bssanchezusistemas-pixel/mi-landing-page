# =============================================
# PIPE EN LA CALLE - Variables de Entorno
# =============================================
# Copia este archivo como .env.local y llena
# tus credenciales de Supabase (opcionales).
# Sin ellas, la app funciona con LocalStorage.
# =============================================

# --- SUPABASE (Opcional) ---
# Consigue estas claves en: https://supabase.com/dashboard
# Settings > API > Project URL & anon public key

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# --- CONFIGURACION DEL SITIO ---
NEXT_PUBLIC_WHATSAPP_NUMBER=573154647189
NEXT_PUBLIC_SITE_NAME=Pipe en la Calle
